# ---------------------------------------------------------------------------
# Copia este archivo a .env y completa los valores. NUNCA subas .env a git.
# ---------------------------------------------------------------------------

# Base de datos Postgres.
#  - Local (Docker): postgresql://fhir:fhir@localhost:5433/fhir?schema=public
#  - Produccion (Neon): usa la cadena "pooled" que te da Neon (incluye sslmode=require)
DATABASE_URL="postgresql://fhir:fhir@localhost:5433/fhir?schema=public"

# Secreto de Auth.js. Genera uno con: npx auth secret  (o: openssl rand -base64 32)
AUTH_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# URL publica de la app (en produccion, la URL de Cloud Run). En local puede omitirse.
# AUTH_URL="https://tu-servicio-xxxx.a.run.app"

# Credenciales OAuth de Google (Google Cloud Console > APIs y servicios > Credenciales).
# Origen autorizado: http://localhost:3000  y tu URL de Cloud Run.
# Redirect URI: <origen>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Correos autorizados (lista blanca), separados por coma.
AUTH_ALLOWLIST="jose.vargas@doctorsv.gob.sv"

# Acceso de prueba sin Google (SOLO desarrollo). Ponlo en "true" para verificar local.
AUTH_ENABLE_DEV_LOGIN="true"

# Tutor IA (se usa desde la Fase 6). Google AI Studio > API key (nivel gratuito).
GEMINI_API_KEY=""
# Proveedor de respaldo opcional (Fase 6): Groq (nivel gratuito).
GROQ_API_KEY=""
